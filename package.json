{
	"name": "d1cli",
	"version": "0.1.0",
	"description": "Interactive SQL REPL for Cloudflare D1 databases",
	"type": "module",
	"bin": {
		"d1cli": "./bin/d1cli.js"
	},
	"main": "./dist/cli.js",
	"files": [
		"bin/",
		"dist/"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/cli.ts",
		"test": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"keywords": [
		"cloudflare",
		"d1",
		"sqlite",
		"repl",
		"cli",
		"sql",
		"database"
	],
	"license": "MIT",
	"dependencies": {
		"ansi-escapes": "^7.3.0",
		"better-sqlite3": "^11.7.0",
		"chalk": "^5.4.1",
		"cli-table3": "^0.6.5",
		"commander": "^13.1.0",
		"smol-toml": "^1.3.1",
		"string-width": "^8.2.0",
		"strip-ansi": "^7.2.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.0",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
